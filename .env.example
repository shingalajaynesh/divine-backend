# Divine backend environment example
# Copy to .env for local development. Never commit real .env files.

# Runtime
NODE_ENV=development
PORT=4000
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:8081

# PostgreSQL - use either DATABASE_URL or the individual DB_* variables below.
# DATABASE_URL=postgresql://<db_user>:<db_password>@<db_host>:5432/<db_name>?sslmode=require
DB_NAME=divine_garbh_sanskar
DB_USER=postgres
DB_PASSWORD=<replace_with_local_database_password>
DB_HOST=localhost
DB_PORT=5432
DB_SSL=false

# Optional database pool tuning
DB_POOL_MAX=5
DB_POOL_MIN=1
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000
SLOW_QUERY_THRESHOLD=300

# Firebase Admin
FIREBASE_PROJECT_ID=<firebase_project_id>
# Optional locally; required for service-account verification in production.
FIREBASE_CLIENT_EMAIL=<firebase_service_account_email>
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n<firebase_private_key>\n-----END PRIVATE KEY-----\n"

# Razorpay server credentials
RAZORPAY_KEY_ID=<razorpay_key_id>
RAZORPAY_KEY_SECRET=<razorpay_key_secret>
RAZORPAY_WEBHOOK_SECRET=<razorpay_webhook_secret>

# Cloudinary server credentials
CLOUDINARY_CLOUD_NAME=<cloudinary_cloud_name>
CLOUDINARY_API_KEY=<cloudinary_api_key>
CLOUDINARY_API_SECRET=<cloudinary_api_secret>

# WhatsApp / Meta Cloud API
WP_FALLBACK_ACCESS_TOKEN=<whatsapp_access_token>
WP_FALLBACK_PHONE_NUMBER_ID=<whatsapp_phone_number_id>
WP_TEMPLATE_DAILY_HI=daily_update_hi
WP_TEMPLATE_DAILY_EN=daily_update_en

# Logging
LOG_LEVEL=info
LOG_FORMAT=dev
LOG_GRAPH_QL_REQUESTS=false
LOG_GRAPH_QL_RESPONSES=false
LOG_GRAPH_QL_VARIABLES=false
LOG_GRAPH_QL_DOCUMENTS=false

# Optional keep-awake ping for limited hosting plans
BACKEND_SELF_PING_URL=
SELF_PING_INTERVAL_MS=600000
