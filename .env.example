PORT=4000
DB_NAME=divine_garbh_sanskar
DB_USER=postgres
DB_PASSWORD=replace_with_a_strong_password
DB_HOST=localhost
DB_PORT=5432
FIREBASE_PROJECT_ID=your-firebase-project-id
# Optional locally; recommended in production. Download from Firebase Console > Project settings > Service accounts.
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@example-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace_me\n-----END PRIVATE KEY-----\n"
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:8081
NODE_ENV=development
SLOW_QUERY_THRESHOLD=300
LOG_LEVEL=info
DB_SSL=false
LOG_GRAPH_QL_REQUESTS=true
LOG_GRAPH_QL_RESPONSES=true
LOG_GRAPH_QL_VARIABLES=false
LOG_GRAPH_QL_DOCUMENTS=false

# Connection string (alternative to individual DB_* parameters)
# DATABASE_URL=postgresql://user:password@host:port/dbname?sslmode=require

# Keep-Alive (Self-Ping) Settings
# BACKEND_SELF_PING_URL=https://your-backend.onrender.com/health
# SELF_PING_INTERVAL_MS=600000

# Database Pooling Settings (Optional, optimized defaults for Neon Tech are 5, 1, 30000, 10000)
# DB_POOL_MAX=5
# DB_POOL_MIN=1
# DB_POOL_ACQUIRE=30000
# DB_POOL_IDLE=10000

# Razorpay Credentials
# RAZORPAY_KEY_ID=your_razorpay_key_id
# RAZORPAY_KEY_SECRET=your_razorpay_key_secret
